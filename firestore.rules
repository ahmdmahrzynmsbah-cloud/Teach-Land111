rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isTeacher() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    // 1. Users collection
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // 2. Courses collection
    match /courses/{courseId} {
      allow read: if true;
      allow create: if isAdmin() || isTeacher();
      allow update: if isSignedIn(); 
      allow delete: if isAdmin() || isTeacher();
    }

    // 3. Lessons collection
    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if isAdmin() || isTeacher();
    }

    // 4. Course Progress collection
    match /course_progress/{progressId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 5. Quizzes collection
    match /quizzes/{quizId} {
      allow read: if true;
      allow write: if isAdmin() || isTeacher();
    }

    // 6. Quiz Submissions collection
    match /quiz_submissions/{submissionId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 7. Quick Notes collection
    match /quick_notes/{noteId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 8. Notifications collection
    match /notifications/{notificationId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 9. Transactions collection
    match /transactions/{transactionId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /wallet_transactions/{transactionId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 10. Reviews collection
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 11. Schedule Events collection
    match /schedule_events/{eventId} {
      allow read: if true;
      allow write: if isAdmin() || isTeacher();
    }

    // 12. Notes collection
    match /notes/{noteId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 13. Focus Sessions collection
    match /focus_sessions/{sessionId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 14. Live Streams
    match /live_streams/{streamId} {
      allow read: if true;
      allow write: if isAdmin() || isTeacher();
      
      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    // 15. Platform Settings collection
    match /platform_settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 16. Course Payments collection
    match /course_payments/{paymentId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 16b. Review Payments collection
    match /review_payments/{paymentId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 17. Recharge Codes collection
    match /recharge_codes/{codeId} {
      allow read, write: if isAdmin();
      allow get: if isSignedIn();
      allow update: if isSignedIn();
    }

    // 18. Course Likes collection
    match /course_likes/{likeId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 19. Tahsili Reviews collection
    match /tahsili_reviews/{reviewId} {
      allow read: if true;
      allow create: if isAdmin() || isTeacher();
      allow update: if isSignedIn();
      allow delete: if isAdmin() || isTeacher();
    }

    // 25. Qudurat Reviews collection
    match /qudurat_reviews/{reviewId} {
      allow read: if true;
      allow create: if isAdmin() || isTeacher();
      allow update: if isSignedIn();
      allow delete: if isAdmin() || isTeacher();
    }
    
    // 26. Question Banks collection
    match /questionBanks/{bankId} {
      allow read: if isTeacher() || isAdmin();
      allow write: if isTeacher() || isAdmin();
    }

    // 20. Secret Links Log collection
    match /secret_links_log/{logId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }
    // 21. Expenses collection
    match /expenses/{expenseId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // 22. Store Categories
    match /store_categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 23. Store Items
    match /store_items/{itemId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isSignedIn();
    }

    // 24. Store Orders / Invoices
    match /store_orders/{orderId} {
      allow read: if true; 
      allow write: if isSignedIn();
    }
  }
}
